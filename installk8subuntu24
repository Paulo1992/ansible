
---
- name: Install Kubernetes
  hosts: "masters, workers"
  gather_facts: yes
  become: yes
  become_method: sudo
  vars_prompt:
    - name: "ansible_become_password"
      prompt: Enter sudo password"
      private: yes

  tasks:

    - name: Create containerd config file
      file:
        path: "/etc/modules-load.d/containerd.conf"
        state: "touch"

    - name: Add config for containerd
      blockinfile:
        path: "/etc/modules-load.d/containerd.conf"
        block: |
              overlay
              br_netfilter

    - name: modprobe
      shell: |
              sudo modprobe overlay
              sudo modprobe br_netfilter
- name: Set system configurations for kubernetes networking
      file:
        path: "/etc/sysctl.d/kubernetes.conf"
        state: "touch"

    - name: Set system configurations for kubernetes networking
      blockinfile:
        path: "/etc/sysctl.d/kubernetes.conf"
        block: |
               net.bridge.bridge-nf-call-iptables = 1
               net.bridge.bridge-nf-call-ip6tables = 1
               net.ipv4.ip_forward = 1

    - name: Apply system configuration
      command: sudo sysctl --system

    - name: Add file to add Containerd Source
      file:
        path: "/etc/apt/sources.list.d/docker.list"
        state: "touch"
- name: Add Containerd Source
      blockinfile:
        path: "/etc/apt/sources.list.d/docker.list"
        block: |
              deb [arch=amd64 signed-by=/etc/apt/keyrings/docker.gpg]   https://download.docker.com/linux/ubuntu noble stable

    - name: Install Containerd dependencies
      shell: |
             sudo apt-get update && sudo apt-get install -y ca-certificates curl gnupg lsb-release
             sudo mkdir -p -m 755 /etc/apt/keyrings
             curl -fsSLo /etc/apt/keyrings/docker.gpg https://download.docker.com/linux/ubuntu/gpg


    - name: Remove Kubernetes dependencies if exist
      shell: |
              sudo rm -rf /etc/apt/sources.list.d/kubernetes.list

- name: Install Containerd
      shell: |
             sudo apt update
             sudo apt install -y containerd.io

    - name: Set containerd config
      shell: |
             containerd config default | sudo tee /etc/containerd/config.toml>/dev/null/ 2>&1
             sudo sed -i 's/SystemdCgroup \=false/SystemdCgroup\=true/g' /etc/containerd/config.toml

    - name: Restart and Enable Containerd
      shell: |
             sudo systemctl restart containerd
             sudo systemctl enable containerd

    - name: Install Kubernetes dependencies
      shell: |
             sudo apt-get update && sudo apt-get install -y apt-transport-https curl
             sudo mkdir -p -m 755 /etc/apt/keyrings
             curl -fsSLo /etc/apt/keyrings/kubernestes-apt-keyrings.gpg https://pkgs.k8s.io/core:/stable:/v1.33/deb/Release.key
- name: Add Kubernetes Source
      blockinfile:
        path: "/etc/apt/sources.list.d/kubernetes.list"
        block: |
              deb[signed-by=/etc/apt/keyrings/kubernetes-apt-keyring.gpg] https://pkgs.k8s.io/core:/stable:/v1.33/deb//


    - name: Install Kubernetes
      shell: |
             sudo apt-get update
             sudo apt-get install -y kubelet kubeadm kubectl
             sudo apt-mark hold kubelet kubeadm kubectl
             sudo swapoff -a

