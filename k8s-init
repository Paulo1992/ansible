---
- name: Install Kubernetes
  hosts: "master1"
  gather_facts: yes
  become: yes
  become_method: sudo
  vars_prompt:
    - name: "ansible_become_password"
      prompt: Enter sudo password"
      private: yes

  tasks:
    - name: Initialize the K8S cluster
      shell: kubeadm init --control-plane-endpoint "k8s-lab:6443" --upload-certs --pod-network-cidr=10.244.0.0/16
      args:
        chdir: $HOME
        creates: cluster_initialized.txt


    - name: Create .kube directory
      become: yes
      become_user: ubuntu
      file:
        path: $HOME/.kube
        state: directory
        mode: 0755

 - name: copies admin.conf to user's kube config
      copy:
        src: /etc/kubernetes/admin.conf
        dest: /home/ubuntu/.kube/config
        remote_src: yes
        owner: ubuntu

    - name: Install Weave Network
      become: yes
      become_user: ubuntu
      shell: kubectl apply -f https://reweave.azurewebsites.net/k8s/v1.33/net.yaml
      args:
        chdir: $HOME
        creates: weave_network_setup.txt

    - name: Get token for joining workers nodes
      shell: kubeadm token create --print-join-command
      register: kubernetes_join_command

    - name: Copy join command to local file
      become: yes
      local_action: copy content="{{ kubernetes_join_command.stdout_lines[0]}}" dest="/tmp/kubernetes_join_command" mode=0777

    #- name: Get token for joining masters nodes
