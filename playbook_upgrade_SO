---
- hosts: all
  gather_facts: yes
  become: yes
  become_method: sudo
  vars_prompt:
    - name: "ansible_become_password"
      prompt: "Enter sudo password"
      private: yes
  tasks:
    - name: Update package lists
      apt:
        update_cache: yes

    - name: Upgrade packages.
      apt:
        upgrade: dist

    - name: Remove dependencies no longer required.
      apt:
        autoremove: yes
